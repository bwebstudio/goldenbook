# ─── Backend root environment template ───────────────────────────────────
# Copy this file to `.env` and fill in real values for local development.
# `.env` is gitignored at the repo root — never commit real secrets.
#
# This file is for tools/scripts that run from the backend root
# (migrations, seeds, audit scripts). The HTTP API has its own
# `api/.env` file.

# ── Firebase (legacy auth migration only — remove when migration is done) ──
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json

# ── Database (Supabase Postgres — Transaction pooler) ──
# Format: postgresql://USER:PASSWORD@HOST:PORT/postgres
# URL-encode special characters in PASSWORD.
DATABASE_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/postgres

# ── Supabase ──
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET_HERE

# ── Translation ──
DEEPL_API_KEY=YOUR_DEEPL_API_KEY_HERE

# ── Stripe (use test credentials locally) ──
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY_HERE
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET_HERE

# ── Dashboard URL ──
DASHBOARD_URL=http://localhost:3001