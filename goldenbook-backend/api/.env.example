# ─── API environment template ────────────────────────────────────────────
# Copy this file to `.env` and fill in real values for local development.
# `.env` is gitignored at the repo root — never commit real secrets.

# ── Server ──
PORT=3001
NODE_ENV=development
API_PREFIX=/api/v1

# ── Database (Supabase Postgres — Transaction pooler) ──
# Format: postgresql://USER:PASSWORD@HOST:PORT/postgres
# URL-encode special characters in PASSWORD.
DATABASE_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/postgres

# ── Supabase ──
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE
# JWT secret from: Supabase → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET_HERE

# ── Stripe ──
# Use test credentials locally. Never commit real secrets.
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET_HERE
DASHBOARD_URL=http://localhost:3000

# ── Translation ──
DEEPL_API_KEY=YOUR_DEEPL_API_KEY_HERE

# ── Email (Resend) — required for verification, invites, password reset ──
RESEND_API_KEY=YOUR_RESEND_API_KEY_HERE
EMAIL_FROM=Goldenbook GO <noreply@example.com>

# ── Public app URL — used for deep links in emails ──
APP_URL=https://your-app-domain.example

# ── Google Maps (server-side) ──
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE