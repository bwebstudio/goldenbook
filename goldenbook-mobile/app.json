{
  "expo": {
    "name": "Goldenbook Go",
    "slug": "goldenbook",
    "version": "1.1.2",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/app-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#161E38"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bwebstudio.goldenbook",
      "buildNumber": "77",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Your location is used to show nearby places and local recommendations.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyAccessedAPITypes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon-android.png",
        "backgroundColor": "#161E38"
      },
      "package": "com.bwebstudio.goldenbook",
      "versionCode": 76,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "blockedPermissions": [
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-asset",
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Your location is used to show nearby places and local recommendations.",
          "locationWhenInUsePermission": "Your location is used to show nearby places and local recommendations."
        }
      ],
      "expo-localization",
      [
        "expo-splash-screen",
        {
          "image": "./assets/app-icon.png",
          "imageWidth": 140,
          "resizeMode": "contain",
          "backgroundColor": "#161E38"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "enableProguardInReleaseBuilds": true,
            "useLegacyPackaging": false
          }
        }
      ],
      "./plugins/withAndroid16KBPages.js"
    ],
    "scheme": "goldenbook",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "134f9bf5-71ef-42f0-bef9-789e42476be1"
      }
    },
    "owner": "goldenbook",
    "runtimeVersion": "1.1.2",
    "updates": {
      "url": "https://u.expo.dev/134f9bf5-71ef-42f0-bef9-789e42476be1"
    }
  }
}
