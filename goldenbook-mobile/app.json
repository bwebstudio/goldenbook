{
  "expo": {
    "name": "Goldenbook Go",
    "slug": "goldenbook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/app-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#161E38"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.goldenbook.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Your location is used to show nearby places and local recommendations."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon-android.png",
        "backgroundColor": "#161E38"
      },
      "package": "com.goldenbook.app"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-asset",
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Your location is used to show nearby places and local recommendations.",
          "locationWhenInUsePermission": "Your location is used to show nearby places and local recommendations."
        }
      ],
      "expo-localization"
    ],
    "scheme": "goldenbook",
    "experiments": {
      "typedRoutes": true
    }
  }
}
