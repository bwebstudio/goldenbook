# ─── Mobile environment template ─────────────────────────────────────────
# Copy this file to `.env` and fill in real values for local development.
# `.env` is gitignored at the repo root — never commit real secrets.

# Backend API base URL (no trailing slash). For local dev use the local API.
EXPO_PUBLIC_API_URL=http://localhost:3001/api/v1

# Supabase project URL (public — safe to expose in client builds)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase publishable / anon key (public — safe to expose in client builds)
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
